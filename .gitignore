# ============================================================
# LaTeX 编译中间文件
# ============================================================

# 核心辅助文件
*.aux
*.bbl
*.blg
*.out
*.toc
*.lof
*.lot

# 日志文件
*.log

# 索引和词汇表
*.idx
*.ind
*.ilg
*.glo
*.gls
*.alg

# 同步和预览文件
*.synctex.gz
*.fdb_latexmk
*.fls

# 临时文件
*.tmp
*.bak
*~

# 交叉引用文件
*.brf
*.nav
*.snm
*.vrb

# 字体缓存（XeLaTeX/LuaLaTeX）
*.xdy

# ============================================================
# 操作系统生成的文件
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================
# 编辑器生成的文件
# ============================================================

# VS Code
.vscode/

# Vim
*.swp
*.swo

# Emacs
*~

# TeXstudio
*.txss

# ============================================================
# 编译输出
# ============================================================

# 忽略所有 PDF
*.pdf

# 保留主 PDF（心河Paper 系统依赖）
!main.pdf

